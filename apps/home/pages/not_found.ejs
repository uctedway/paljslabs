<section class="notfound-page">
  <% const L = (ko, en) => tt(ko, en); %>
  <div class="notfound-card">
    <p class="notfound-kicker">404 NOT FOUND</p>
    <h1><%= L('요청하신 페이지를 찾을 수 없습니다.', 'The page you requested could not be found.') %></h1>
    <p><%= L('주소가 변경되었거나 삭제되었을 수 있습니다. 메인 화면에서 다시 이동해 주세요.', 'The URL may have changed or the page may have been removed.') %></p>

    <div class="notfound-actions">
      <a class="notfound-btn-primary" href="/"><%= L('홈으로 이동', 'Go Home') %></a>
      <a class="notfound-btn-secondary" href="/fortune"><%= L('운세 메뉴로 이동', 'Go to Fortune Menu') %></a>
    </div>
  </div>
</section>
