<section class="system-maintenance-page">
  <% const L = (ko, en) => tt(ko, en); %>
  <div class="system-maintenance-card">
    <p class="maintenance-kicker">System Notice</p>
    <h1><%= L('현재 AI 분석 서버 점검 중입니다', 'AI analysis server is under maintenance') %></h1>
    <p>
      <%= L('일시적으로 외부 AI 분석 서비스 사용이 제한되어 요청을 처리할 수 없습니다.', 'External AI analysis is temporarily unavailable, so requests cannot be processed right now.') %>
      <%= L('잠시 후 다시 시도해 주세요.', 'Please try again shortly.') %>
    </p>

    <div class="maintenance-info">
      <p><strong><%= L('영향 범위', 'Affected Scope') %></strong> <%= L('사주/운세 신규 분석 요청', 'New Saju/Fortune analysis requests') %></p>
      <p><strong><%= L('현재 상태', 'Current Status') %></strong> <%= L('복구 작업 진행 중', 'Recovery in progress') %></p>
    </div>

    <div class="maintenance-actions">
      <a class="maintenance-btn-primary" href="/"><%= L('홈으로 이동', 'Go Home') %></a>
      <a class="maintenance-btn-secondary" href="/fortune"><%= L('운세 메뉴로 이동', 'Go to Fortune Menu') %></a>
    </div>
  </div>
</section>
