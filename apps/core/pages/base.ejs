<!DOCTYPE html>
<html lang="<%= String(locale || 'ko') %>">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<%
		const pageSeo = (typeof seo !== 'undefined' && seo) ? seo : {};
		const pageTitle = String(pageSeo.title || title || '48LAB');
		const pageDescription = String(pageSeo.description || '48LAB 서비스');
		const pageKeywords = String(pageSeo.keywords || '');
		const pageCanonical = String(pageSeo.canonical || '');
		const pageRobots = String(pageSeo.robots || 'index, follow');
		const pageImage = String(pageSeo.image || '');
		const pageStructuredData = Array.isArray(pageSeo.structuredData) ? pageSeo.structuredData : [];
		const pageAlternates = (pageSeo.alternates && typeof pageSeo.alternates === 'object') ? pageSeo.alternates : null;
	%>
	<title><%= pageTitle %></title>
	<meta name="description" content="<%= pageDescription %>">
	<% if (pageKeywords) { %><meta name="keywords" content="<%= pageKeywords %>"><% } %>
	<meta name="robots" content="<%= pageRobots %>">
	<meta property="og:locale" content="<%= String(ogLocale || 'ko_KR') %>">
	<% if (String(locale || 'ko') === 'ko') { %>
	<meta property="og:locale:alternate" content="en_US">
	<% } else { %>
	<meta property="og:locale:alternate" content="ko_KR">
	<% } %>
	<meta property="og:type" content="<%= String(pageSeo.ogType || 'website') %>">
	<meta property="og:site_name" content="48LAB">
	<meta property="og:title" content="<%= pageTitle %>">
	<meta property="og:description" content="<%= pageDescription %>">
	<% if (pageCanonical) { %>
	<link rel="canonical" href="<%= pageCanonical %>">
	<meta property="og:url" content="<%= pageCanonical %>">
	<% } %>
	<% if (pageAlternates) { %>
		<% if (pageAlternates.ko) { %><link rel="alternate" hreflang="ko-KR" href="<%= pageAlternates.ko %>"><% } %>
		<% if (pageAlternates.en) { %><link rel="alternate" hreflang="en-US" href="<%= pageAlternates.en %>"><% } %>
		<% if (pageAlternates['x-default']) { %><link rel="alternate" hreflang="x-default" href="<%= pageAlternates['x-default'] %>"><% } %>
	<% } %>
	<% if (pageImage) { %>
	<meta property="og:image" content="<%= pageImage %>">
	<meta name="twitter:image" content="<%= pageImage %>">
	<% } %>
	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:title" content="<%= pageTitle %>">
	<meta name="twitter:description" content="<%= pageDescription %>">
	<script>
	(function () {
		try {
			var mode = localStorage.getItem('theme.mode');
			if (mode !== 'light') {
				document.documentElement.classList.add('theme-dark');
			}
		} catch (_) {}
	})();
	</script>
	<link rel="stylesheet" href="/css/style.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
	<% pageStructuredData.forEach((schema) => { %>
	<script type="application/ld+json"><%- JSON.stringify(schema) %></script>
	<% }) %>
</head>
<body>
	<%
		const currentRoute = String(currentPath || '/');
		const showBetaModalOnThisPage = !currentRoute.startsWith('/manage');
	%>
	<% if (showBetaModalOnThisPage) { %>
	<div class="beta-notice-modal" id="betaNoticeModal" role="dialog" aria-modal="true" aria-labelledby="betaNoticeTitle" aria-hidden="true">
		<div class="beta-notice-backdrop" data-beta-close></div>
		<div class="beta-notice-panel">
			<div class="beta-notice-icon-wrap" aria-hidden="true">
				<img class="beta-notice-icon" src="/images/icons/material/fact_check.svg" alt="">
			</div>
			<h2 id="betaNoticeTitle"><%= locale === 'en' ? 'Beta Notice' : '베타 테스트 안내' %></h2>
			<p>
				<%= locale === 'en'
					? '48LAB is currently in beta and under active development. Current outputs are preview-level and are not final real analysis.'
					: '48LAB는 현재 베타 테스트 및 개발 진행 중입니다. 현재 제공되는 결과는 미리보기 수준이며 실제 최종 분석이 아닙니다.' %>
			</p>
			<p class="beta-notice-coming"><%= locale === 'en' ? 'Coming Soon!' : '커밍순!' %></p>
			<div class="beta-notice-actions">
				<button type="button" class="beta-notice-btn beta-notice-btn--ghost" data-beta-hide-today>
					<%= locale === 'en' ? "Don't show today" : '오늘 보지 않기' %>
				</button>
				<button type="button" class="beta-notice-btn" data-beta-close>
					<%= locale === 'en' ? 'Close' : '확인' %>
				</button>
			</div>
		</div>
	</div>
	<% } %>
	<div class="container">
		<%- include('header') %>
		
		<main class="main">
			<%- body %>
		</main>
		
		<%- include('footer') %>
	</div>
	<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
	<script src="/js/modules/global_toast.js"></script>
	<script type="module" src="/js/modules/theme_mode.js"></script>
	<% if (showBetaModalOnThisPage) { %>
	<script>
	(function () {
		var modal = document.getElementById('betaNoticeModal');
		if (!modal) return;
		var closeEls = modal.querySelectorAll('[data-beta-close]');
		var hideTodayEl = modal.querySelector('[data-beta-hide-today]');
		var storageKey = 'beta_notice_hide_date';
		var now = new Date();
		var yyyy = String(now.getFullYear());
		var mm = String(now.getMonth() + 1).padStart(2, '0');
		var dd = String(now.getDate()).padStart(2, '0');
		var today = yyyy + '-' + mm + '-' + dd;

		function closeModal() {
			modal.classList.remove('is-open');
			modal.setAttribute('aria-hidden', 'true');
			document.body.classList.remove('beta-notice-open');
		}

		function openModal() {
			modal.classList.add('is-open');
			modal.setAttribute('aria-hidden', 'false');
			document.body.classList.add('beta-notice-open');
		}

		try {
			var hiddenDate = localStorage.getItem(storageKey);
			if (hiddenDate === today) return;
		} catch (_) {}

		openModal();
		closeEls.forEach(function (el) {
			el.addEventListener('click', closeModal);
		});
		if (hideTodayEl) {
			hideTodayEl.addEventListener('click', function () {
				try {
					localStorage.setItem(storageKey, today);
				} catch (_) {}
				closeModal();
			});
		}
		window.addEventListener('keydown', function (e) {
			if (!modal.classList.contains('is-open')) return;
			if (e.key === 'Escape') closeModal();
		});
	})();
	</script>
	<% } %>
	<%- script %>
</body>
</html>
