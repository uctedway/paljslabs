<% const L = (ko, en) => tt(ko, en); %>
<div class="result-container">
  <div class="result-header">
    <h1><%= locale === 'en' ? `${featureTitle} Result` : `${featureTitle} 결과` %></h1>
    <p class="birth-info"><%= L('결과 ID', 'Result ID') %>: <%= resultId %></p>
    <% if (summary) { %>
      <p class="birth-info"><%= summary %></p>
    <% } %>
  </div>

  <div id="result-content" class="result-content"></div>

  <div class="result-actions">
    <a href="/fortune" class="btn-home"><%= L('다른 메뉴 보기', 'Browse Other Menus') %></a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js"></script>
<script>
  const markdown = <%- JSON.stringify(claudeResult) %>;
  const unsafeHtml = marked.parse(markdown || <%- JSON.stringify(tt('결과가 없습니다.', 'No result available.')) %>);
  const safeHtml = DOMPurify.sanitize(unsafeHtml);
  document.getElementById('result-content').innerHTML = safeHtml;
</script>
