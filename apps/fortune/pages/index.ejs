<% const L = (ko, en) => tt(ko, en); %>
<section class="fortune-hub-page">
  <header class="fortune-hub-hero">
    <p class="fortune-hub-kicker">Fortune Services</p>
    <h1><%= L('원하는 운세를 먼저 이해하고 시작하세요', 'Understand each service before you start') %></h1>
    <p>
      <%= L('각 서비스의 목적과 해석 범위를 먼저 확인한 뒤, 버튼을 눌러 입력폼으로 이동합니다.', 'Review each service purpose and interpretation scope, then move to the form.') %>
      <%= L('운세 용어가 익숙하지 않아도 이해할 수 있도록 설명 중심으로 구성했습니다.', 'Descriptions are written to be clear even if fortune terms are unfamiliar.') %>
    </p>
  </header>

  <section class="fortune-hub-board" aria-label="<%= L('운세 서비스 목록', 'Fortune service list') %>">
    <% 
      const cardThemeMap = {
        compatibility: 'compatibility',
        today: 'today',
        flow: 'flow',
        naming: 'naming',
        'date-selection': 'date-selection',
      };
      const cardTaglineMap = {
        compatibility: L('관계 리듬 분석', 'Relationship rhythm'),
        today: L('하루 우선순위 가이드', 'Daily priorities'),
        flow: L('중장기 타이밍 전략', 'Mid/long-term timing'),
        naming: L('이름 후보 비교 분석', 'Name candidate comparison'),
        'date-selection': L('중요 일정 적합도 비교', 'Date suitability comparison'),
      };
    %>

    <% (features || []).forEach(function(feature) { %>
      <% const theme = cardThemeMap[feature.key] || 'today'; %>
      <article class="fortune-hub-card theme-<%= theme %>">
        <div class="fortune-hub-card-bg" aria-hidden="true"></div>
        <div class="fortune-hub-card-overlay" aria-hidden="true"></div>

        <div class="fortune-hub-card-body">
          <p class="fortune-hub-card-tag"><%= cardTaglineMap[feature.key] || L('설명형 운세 서비스', 'Guided fortune service') %></p>
          <h2><%= feature.title %></h2>
          <p class="fortune-hub-card-desc"><%= feature.description %></p>

          <div class="fortune-hub-card-actions">
            <a class="fortune-hub-btn-primary" href="/fortune/<%= feature.key %>"><%= L('서비스 설명 보기', 'View Service Guide') %></a>
            <a class="fortune-hub-btn-ghost" href="/fortune/<%= feature.key %>?view=form"><%= L('바로 입력하기', 'Go to Form') %></a>
          </div>
        </div>
      </article>
    <% }) %>
  </section>
</section>
