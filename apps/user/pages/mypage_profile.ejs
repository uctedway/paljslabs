<section class="mypage-shell">
  <% const L = (ko, en) => tt(ko, en); %>
  <%- include('./partials/mypage_sidebar', { currentMenu, consultationHistory, relatives }) %>
  <% const currentYear = new Date().getFullYear(); %>
  <% const birthParts = String(profile.birthDate || '').split('-'); %>
  <% const selectedBirthYear = birthParts[0] || ''; %>
  <% const selectedBirthMonth = birthParts[1] || ''; %>
  <% const selectedBirthDay = birthParts[2] || ''; %>

  <div class="mypage-content">
    <article class="mypage-card">
      <h3><%= L('내 정보수정', 'Edit Profile') %></h3>
      <p class="mypage-desc"><%= L('생년월일시와 성별 정보를 저장합니다.', 'Save your birth date/time and gender.') %></p>

      <form method="POST" data-action="/user/mypage/profile/update">
        <div class="mypage-grid">
          <label>
            <span><%= L('생년월일', 'Birth Date') %></span>
            <div class="mypage-birth-selects">
              <select name="birthYear" class="mustInput" data-alert="<%= L('생년(연도)을 선택해주세요.', 'Please select birth year.') %>">
                <option value=""><%= L('연도', 'Year') %></option>
                <% for (let y = currentYear; y >= 1900; y--) { %>
                  <option value="<%= y %>" <%= String(y) === selectedBirthYear ? 'selected' : '' %>><%= locale === 'en' ? y : `${y}년` %></option>
                <% } %>
              </select>
              <select name="birthMonth" class="mustInput" data-alert="<%= L('생월(월)을 선택해주세요.', 'Please select birth month.') %>">
                <option value=""><%= L('월', 'Month') %></option>
                <% for (let m = 1; m <= 12; m++) { %>
                  <% const mv = String(m).padStart(2, '0'); %>
                  <option value="<%= m %>" <%= mv === selectedBirthMonth ? 'selected' : '' %>><%= locale === 'en' ? m : `${m}월` %></option>
                <% } %>
              </select>
              <select name="birthDay" class="mustInput" data-alert="<%= L('생일(일)을 선택해주세요.', 'Please select birth day.') %>">
                <option value=""><%= L('일', 'Day') %></option>
                <% for (let d = 1; d <= 31; d++) { %>
                  <% const dv = String(d).padStart(2, '0'); %>
                  <option value="<%= d %>" <%= dv === selectedBirthDay ? 'selected' : '' %>><%= locale === 'en' ? d : `${d}일` %></option>
                <% } %>
              </select>
            </div>
          </label>

          <label>
            <span><%= L('태어난 시간', 'Birth Time') %></span>
            <select name="birthTime" class="mustInput" data-alert="<%= L('태어난 시간을 선택해주세요.', 'Please select birth time.') %>">
              <option value=""><%= L('시간 선택', 'Select Time') %></option>
              <option value="00:30:00" <%= profile.birthTime === '00:30:00' ? 'selected' : '' %>><%= L('자시', 'Zi') %> (23:30~01:30)</option>
              <option value="02:30:00" <%= profile.birthTime === '02:30:00' ? 'selected' : '' %>><%= L('축시', 'Chou') %> (01:30~03:30)</option>
              <option value="04:30:00" <%= profile.birthTime === '04:30:00' ? 'selected' : '' %>><%= L('인시', 'Yin') %> (03:30~05:30)</option>
              <option value="06:30:00" <%= profile.birthTime === '06:30:00' ? 'selected' : '' %>><%= L('묘시', 'Mao') %> (05:30~07:30)</option>
              <option value="08:30:00" <%= profile.birthTime === '08:30:00' ? 'selected' : '' %>><%= L('진시', 'Chen') %> (07:30~09:30)</option>
              <option value="10:30:00" <%= profile.birthTime === '10:30:00' ? 'selected' : '' %>><%= L('사시', 'Si') %> (09:30~11:30)</option>
              <option value="12:30:00" <%= profile.birthTime === '12:30:00' ? 'selected' : '' %>><%= L('오시', 'Wu') %> (11:30~13:30)</option>
              <option value="14:30:00" <%= profile.birthTime === '14:30:00' ? 'selected' : '' %>><%= L('미시', 'Wei') %> (13:30~15:30)</option>
              <option value="16:30:00" <%= profile.birthTime === '16:30:00' ? 'selected' : '' %>><%= L('신시', 'Shen') %> (15:30~17:30)</option>
              <option value="18:30:00" <%= profile.birthTime === '18:30:00' ? 'selected' : '' %>><%= L('유시', 'You') %> (17:30~19:30)</option>
              <option value="20:30:00" <%= profile.birthTime === '20:30:00' ? 'selected' : '' %>><%= L('술시', 'Xu') %> (19:30~21:30)</option>
              <option value="22:30:00" <%= profile.birthTime === '22:30:00' ? 'selected' : '' %>><%= L('해시', 'Hai') %> (21:30~23:30)</option>
              <option value="99:99:99" <%= profile.birthTime === '99:99:99' ? 'selected' : '' %>><%= L('모름', 'Unknown') %></option>
            </select>
          </label>
        </div>

        <fieldset class="mypage-radio-group">
          <legend><%= L('성별', 'Gender') %></legend>
          <label>
            <input type="radio" name="gender" value="male" class="mustInput" data-alert="<%= L('성별을 선택해주세요.', 'Please select gender.') %>" <%= profile.gender === 'male' ? 'checked' : '' %>>
            <span><%= L('남성', 'Male') %></span>
          </label>
          <label>
            <input type="radio" name="gender" value="female" class="mustInput" data-alert="<%= L('성별을 선택해주세요.', 'Please select gender.') %>" <%= profile.gender === 'female' ? 'checked' : '' %>>
            <span><%= L('여성', 'Female') %></span>
          </label>
        </fieldset>

        <button type="submit" class="mypage-btn primary"><%= L('내 정보 저장', 'Save Profile') %></button>
      </form>
    </article>
  </div>
</section>

<script type="module">
  import { initFormContainer } from '/js/modules/form.js';
  initFormContainer();
</script>
