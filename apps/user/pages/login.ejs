<main class="login-page">
  <section class="login-hero">
	<div class="login-card">
	  <% const mode = (authMode === 'register') ? 'register' : 'login'; %>
	  <% const L = (ko, en) => tt(ko, en); %>
	  <% const socialActionText = L('계속하기', 'Continue'); %>
	  <p class="login-kicker">48LAB ACCOUNT</p>
	  <h1 class="login-title"><%= mode === 'register' ? L('48LAB 회원가입', '48LAB Sign Up') : L('48LAB 로그인', '48LAB Login') %></h1>
	  <p class="login-lead"><%= L('원하는 소셜 계정으로 빠르게 시작하세요.', 'Start quickly with your preferred social account.') %></p>
	  <% if (mode === 'register') { %>
		<section class="signup-consent-section">
		  <h2 class="signup-consent-title"><%= L('회원가입 약관 동의', 'Sign-up Consent') %></h2>
		  <div class="signup-consent-grid">
			<div class="signup-consent-panel">
			  <p class="signup-consent-panel-title"><%= L('이용약관', 'Terms') %></p>
			  <div class="signup-consent-scroll">
				<%- include('../../core/pages/partials/legal_terms_content') %>
			  </div>
			</div>
			<div class="signup-consent-panel">
			  <p class="signup-consent-panel-title"><%= L('개인정보처리방침', 'Privacy Policy') %></p>
			  <div class="signup-consent-scroll">
				<%- include('../../core/pages/partials/legal_privacy_content') %>
			  </div>
			</div>
		  </div>
		  <div class="signup-consent-checks">
			<label class="signup-consent-check"><input type="checkbox" id="agree-terms"> <%= L('이용약관에 동의합니다. (필수)', 'I agree to the Terms. (Required)') %></label>
			<label class="signup-consent-check"><input type="checkbox" id="agree-privacy"> <%= L('개인정보처리방침에 동의합니다. (필수)', 'I agree to the Privacy Policy. (Required)') %></label>
		  </div>
		</section>
	  <% } %>

	  <script src="https://accounts.google.com/gsi/client" async defer></script>

	  <div
		id="g_id_onload"
		data-client_id="<%= googleClientId %>"
		data-callback="googleHandleCredentialResponse"
		data-auto_prompt="false">
	  </div>

	  <div class="login-providers">
		<div class="google-signin-wrap">
		  <div
			class="g_id_signin"
			data-type="standard"
			data-size="large"
			data-theme="outline"
			data-text="signin_with"
			data-shape="rectangular"
			data-logo_alignment="left"
			data-width="420">
		  </div>
		</div>

		<a class="provider-row naver-signin-btn <%= naverLoginUrl ? '' : 'is-disabled' %>" href="<%= naverLoginUrl || '#' %>">
		  <span class="provider-icon" aria-hidden="true">
			<img src="/images/icons/social/naver.svg" alt="">
		  </span>
		  <span class="provider-label"><%= L('네이버로', 'With Naver') %> <%= socialActionText %></span>
		</a>
		<a class="provider-row kakao-signin-btn <%= kakaoLoginUrl ? '' : 'is-disabled' %>" href="<%= kakaoLoginUrl || '#' %>">
		  <span class="provider-icon" aria-hidden="true">
			<img src="/images/icons/social/kakao.svg" alt="">
		  </span>
		  <span class="provider-label"><%= L('카카오로', 'With Kakao') %> <%= socialActionText %></span>
		</a>
		<a class="provider-row apple-signin-btn <%= appleLoginUrl ? '' : 'is-disabled' %>" href="<%= appleLoginUrl || '#' %>">
		  <span class="provider-icon" aria-hidden="true">
			<img src="/images/icons/social/apple.svg" alt="">
		  </span>
		  <span class="provider-label">Apple <%= socialActionText %></span>
		</a>
	  </div>

	  <a class="email-entry-btn" href="<%= mode === 'register' ? '/user/email-register' : '/user/email-login' %>">
		<%= mode === 'register' ? L('이메일로 회원가입', 'Sign up with Email') : L('이메일로 로그인', 'Login with Email') %>
	  </a>

	  <p class="login-subtext">
		<% if (mode === 'register') { %>
		  <%= L('이미 계정이 있으신가요?', 'Already have an account?') %> <a href="/user/login"><%= L('로그인', 'Login') %></a>
		<% } else { %>
		  <%= L('아직 계정이 없으신가요?', "Don't have an account yet?") %> <a href="/user/register"><%= L('회원가입', 'Sign up') %></a>
		<% } %>
	  </p>

	  <script type="module">
		import { googleHandleCredentialResponse } from '/js/modules/apps/user/google_auth.js';
		import { initSignupConsentGate } from '/js/modules/apps/user/signup_consent.js';
		// GSI는 반드시 window에서 콜백을 찾음
		window.socialAuthIntent = '<%= mode %>';
		window.googleHandleCredentialResponse = googleHandleCredentialResponse;
		initSignupConsentGate();
		const loginErrorMessage = <%- JSON.stringify(String(loginErrorMessage || '')) %>;
		if (loginErrorMessage && window.AppToast && typeof window.AppToast.show === 'function') {
			window.AppToast.show(loginErrorMessage, { type: 'warning', duration: 2800 });
		}
	  </script>
	</div>
  </section>
</main>
